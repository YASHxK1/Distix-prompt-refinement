{
  "manifest_version": 3,
  "name": "prompt-refinement",
  "version": "1.0.0",
  "description": "Refine prompts in ChatGPT, Claude, DeepSeek, or the extension popup using Vercel AI Gateway.",
  "minimum_chrome_version": "102",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://chat.deepseek.com/*",
    "https://ai-gateway.vercel.sh/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_title": "Refine a prompt",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://chat.deepseek.com/*"
      ],
      "css": [
        "content/content.css"
      ],
      "js": [
        "shared/constants.js",
        "shared/validation.js",
        "shared/ui.js",
        "content/adapters.js",
        "content/content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
